# ── Project ────────────────────────────────────────
PROJECT_NAME="EduSync ERP"
API_VERSION="v1"

# ── MongoDB ────────────────────────────────────────
MONGODB_URI="mongodb://localhost:27017"
DATABASE_NAME="edusync_db"

# ── JWT Authentication ─────────────────────────────
JWT_SECRET_KEY="replace-with-a-long-random-secret-key-min-32-chars"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── College Settings ───────────────────────────────
COLLEGE_EMAIL_DOMAIN=college.edu
